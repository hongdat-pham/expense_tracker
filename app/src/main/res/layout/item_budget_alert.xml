<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    android:background="@drawable/rounded_bg_surface_lowest"
    android:orientation="vertical"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="10dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <!-- Icon container — màu nền set từ code -->
        <FrameLayout
            android:id="@+id/iconContainer"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/rounded_icon_bg">

            <TextView
                android:id="@+id/tvIcon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:fontFamily="@font/inter"
                android:textColor="@color/on_surface_variant"
                android:textSize="20sp"
                tools:text="restaurant" />

        </FrameLayout>

        <!-- Tên + spending info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="12dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvCategoryName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/inter"
                android:textColor="@color/on_surface"
                android:textSize="14sp"
                android:textStyle="bold"
                tools:text="Food &amp; Drink" />

            <TextView
                android:id="@+id/tvSpentInfo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/inter"
                android:textColor="@color/on_surface_variant"
                android:textSize="12sp"
                tools:text="Spent $640 of $800" />

        </LinearLayout>

        <!-- Phần trăm -->
        <TextView
            android:id="@+id/tvPercent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/inter"
            android:textColor="@color/error"
            android:textSize="13sp"
            android:textStyle="bold"
            tools:text="80%" />

    </LinearLayout>

    <com.google.android.material.progressindicator.LinearProgressIndicator
        android:id="@+id/progressBudget"
        android:layout_width="match_parent"
        android:layout_height="8dp"
        app:indicatorColor="@color/error"
        android:progress="80"
        app:trackColor="@color/surface_container_low"
        app:trackCornerRadius="8dp" />

</LinearLayout>