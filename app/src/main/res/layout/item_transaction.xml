<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/transaction_item_bg"
    android:foreground="?attr/selectableItemBackground"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="16dp">

    <!-- Category Icon Container -->
    <FrameLayout
        android:id="@+id/iconContainer"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:background="@drawable/rounded_icon_bg">

        <ImageView
            android:id="@+id/ivIcon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="center"
            tools:src="@drawable/ic_restaurant" />

    </FrameLayout>

    <!-- Tên + category tag -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="12dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvMerchantName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:fontFamily="@font/inter"
            android:maxLines="1"
            android:textColor="@color/on_surface"
            android:textSize="14sp"
            android:textStyle="bold"
            tools:text="Whole Foods Market" />

        <TextView
            android:id="@+id/tvCategoryTag"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:background="@drawable/badge_neutral_bg"
            android:fontFamily="@font/inter"
            android:paddingHorizontal="8dp"
            android:paddingVertical="2dp"
            android:textColor="@color/on_surface_variant"
            android:textSize="10sp"
            android:textStyle="bold"
            tools:text="Groceries" />

    </LinearLayout>

    <!-- Số tiền + giờ -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="end"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvAmount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/manrope"
            android:textSize="16sp"
            android:textStyle="bold"
            tools:text="-$84.20" />

        <TextView
            android:id="@+id/tvTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:fontFamily="@font/inter"
            android:textColor="@color/on_surface_variant"
            android:textSize="11sp"
            tools:text="10:45 AM" />

    </LinearLayout>

</LinearLayout>