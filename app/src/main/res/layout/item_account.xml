<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    android:background="@drawable/rounded_bg_surface_lowest"
    android:elevation="1dp"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="16dp">

    <!-- Account icon -->
    <ImageView
        android:id="@+id/ivAccountIcon"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:background="@drawable/circle_surface_bg"
        android:padding="10dp"
        app:tint="@color/primary"
        tools:src="@drawable/ic_wallet" />

    <!-- Name + meta -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvAccountName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/inter"
            android:textColor="@color/on_surface"
            android:textSize="15sp"
            android:textStyle="bold"
            tools:text="Chase Bank" />

        <TextView
            android:id="@+id/tvAccountMeta"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:fontFamily="@font/inter"
            android:textColor="@color/on_surface_variant"
            android:textSize="12sp"
            tools:text="Savings •••• 4291" />

    </LinearLayout>

    <!-- Action buttons -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <ImageButton
            android:id="@+id/btnEdit"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Edit account"
            android:src="@drawable/ic_edit"
            android:visibility="gone"
            app:tint="@color/outline" />

        <ImageButton
            android:id="@+id/btnDelete"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Delete account"
            android:src="@drawable/ic_delete"
            android:visibility="gone"
            app:tint="@color/error" />

    </LinearLayout>

</LinearLayout>