<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface">

    <!-- TopAppBar -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        app:elevation="0dp">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:paddingHorizontal="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <!-- ĐÃ XÓA btnMenu -->

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="@font/manrope"
                    android:gravity="center"
                    android:text="Ventura Finance"
                    android:textColor="@color/primary"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <!-- ĐÃ XÓA ivAvatar -->

            </LinearLayout>
        </androidx.appcompat.widget.Toolbar>
    </com.google.android.material.appbar.AppBarLayout>

    <!-- Scrollable Content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="100dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingTop="8dp">

            <!-- Total Portfolio Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/inter"
                    android:letterSpacing="0.1"
                    android:text="Total Portfolio"
                    android:textAllCaps="true"
                    android:textColor="@color/on_surface_variant"
                    android:textSize="11sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:layout_marginTop="4dp"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tvTotalBalance"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/manrope"
                        android:text="$0.00"
                        android:textColor="@color/on_surface"
                        android:textSize="36sp"
                        android:textStyle="bold"
                        tools:text="$12,480.00" />

                    <TextView
                        android:id="@+id/tvBalanceChange"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/badge_income_bg"
                        android:fontFamily="@font/inter"
                        android:paddingHorizontal="8dp"
                        android:paddingVertical="2dp"
                        android:text="+2.4%"
                        android:textColor="@color/tertiary"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                </LinearLayout>
            </LinearLayout>

            <!-- Monthly Spending Card (Gradient) -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardMonthlySpending"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@android:color/transparent"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/gradient_primary"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/inter"
                                android:letterSpacing="0.1"
                                android:text="Monthly Spending"
                                android:textAllCaps="true"
                                android:textColor="@color/on_primary_container"
                                android:textSize="11sp" />

                            <TextView
                                android:id="@+id/tvMonthlySpent"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:fontFamily="@font/manrope"
                                android:text="$0.00"
                                android:textColor="@color/on_primary"
                                android:textSize="28sp"
                                android:textStyle="bold"
                                tools:text="$3,240.50" />

                        </LinearLayout>

                        <ImageView
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:alpha="0.4"
                            android:src="@drawable/ic_payments"
                            app:tint="@color/primary_fixed" />

                    </LinearLayout>

                    <!-- Mini Bar Chart Placeholder -->
                    <LinearLayout
                        android:id="@+id/miniChartContainer"
                        android:layout_width="match_parent"
                        android:layout_height="80dp"
                        android:layout_marginTop="16dp"
                        android:gravity="bottom"
                        android:orientation="horizontal"
                        android:weightSum="7">

                        <View android:layout_width="0dp" android:layout_height="40dp"
                            android:layout_weight="1" android:layout_marginHorizontal="2dp"
                            android:background="@drawable/mini_bar_bg" />
                        <View android:layout_width="0dp" android:layout_height="55dp"
                            android:layout_weight="1" android:layout_marginHorizontal="2dp"
                            android:background="@drawable/mini_bar_bg" />
                        <View android:layout_width="0dp" android:layout_height="65dp"
                            android:layout_weight="1" android:layout_marginHorizontal="2dp"
                            android:background="@drawable/mini_bar_bg" />
                        <View android:layout_width="0dp" android:layout_height="80dp"
                            android:layout_weight="1" android:layout_marginHorizontal="2dp"
                            android:background="@drawable/mini_bar_active_bg" />
                        <View android:layout_width="0dp" android:layout_height="55dp"
                            android:layout_weight="1" android:layout_marginHorizontal="2dp"
                            android:background="@drawable/mini_bar_bg" />
                        <View android:layout_width="0dp" android:layout_height="45dp"
                            android:layout_weight="1" android:layout_marginHorizontal="2dp"
                            android:background="@drawable/mini_bar_bg" />
                        <View android:layout_width="0dp" android:layout_height="35dp"
                            android:layout_weight="1" android:layout_marginHorizontal="2dp"
                            android:background="@drawable/mini_bar_bg" />

                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Budget Remaining Card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardBudgetRemaining"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardBackgroundColor="@color/surface_container_lowest"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:fontFamily="@font/manrope"
                            android:text="Budget Left"
                            android:textColor="@color/on_surface"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/tvBudgetRemaining"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/inter"
                                android:text="$0"
                                android:textColor="@color/primary"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                tools:text="$850" />

                            <TextView
                                android:id="@+id/tvBudgetTotal"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/inter"
                                android:text=" / $0k"
                                android:textColor="@color/on_surface_variant"
                                android:textSize="12sp"
                                tools:text=" / $4k" />

                        </LinearLayout>
                    </LinearLayout>

                    <com.google.android.material.progressindicator.LinearProgressIndicator
                        android:id="@+id/progressBudget"
                        android:layout_width="match_parent"
                        android:layout_height="10dp"
                        android:layout_marginTop="12dp"
                        app:indicatorColor="@color/primary"
                        android:progress="78"
                        app:trackColor="@color/surface_container_high"
                        app:trackCornerRadius="8dp" />

                    <TextView
                        android:id="@+id/tvBudgetPercent"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:fontFamily="@font/inter"
                        android:text="You've reached 0% of your monthly limit."
                        android:textColor="@color/on_surface_variant"
                        android:textSize="12sp"
                        tools:text="You've reached 78% of your monthly limit." />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Alert Budgets Section (visible when budget over 50%) -->
            <LinearLayout
                android:id="@+id/sectionAlertBudgets"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:orientation="vertical"
                android:visibility="gone"
                tools:visibility="visible">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:fontFamily="@font/manrope"
                    android:text="Budget Alerts"
                    android:textColor="@color/on_surface"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvAlertBudgets"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    tools:itemCount="2"
                    tools:listitem="@layout/item_budget_alert" />

            </LinearLayout>

            <!-- Recent Transactions Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="@font/manrope"
                    android:text="Recent Transactions"
                    android:textColor="@color/on_surface"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvViewAll"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="?attr/selectableItemBackground"
                    android:fontFamily="@font/inter"
                    android:padding="4dp"
                    android:text="View All"
                    android:textColor="@color/primary"
                    android:textSize="13sp"
                    android:textStyle="bold" />

            </LinearLayout>

            <!-- Transaction List Container -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/rounded_container_bg"
                android:padding="8dp">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvRecentTransactions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    tools:itemCount="4"
                    tools:listitem="@layout/item_transaction" />

            </LinearLayout>

            <!-- Empty state for recent transactions -->
            <LinearLayout
                android:id="@+id/emptyRecentState"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="32dp"
                android:visibility="gone"
                tools:visibility="gone">

                <ImageView
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:alpha="0.4"
                    android:src="@drawable/ic_receipt"
                    app:tint="@color/on_surface_variant" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:fontFamily="@font/inter"
                    android:text="No transactions yet"
                    android:textColor="@color/on_surface_variant"
                    android:textSize="14sp" />

            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- FAB -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAddTransaction"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="24dp"
        android:layout_marginBottom="88dp"
        android:contentDescription="Add Transaction"
        android:src="@drawable/ic_add"
        app:backgroundTint="@color/primary"
        app:borderWidth="0dp"
        app:elevation="8dp"
        app:fabSize="normal"
        app:tint="@color/on_primary" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>