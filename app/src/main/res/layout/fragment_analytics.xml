<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/scrollView"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface"
    android:clipToPadding="false"
    android:paddingBottom="100dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="80dp">

        <!-- ── HEADER ──────────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingBottom="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/inter_semi_bold"
                android:letterSpacing="0.15"
                android:text="FINANCIAL INTELLIGENCE"
                android:textAllCaps="true"
                android:textColor="@color/on_surface_variant"
                android:textSize="10sp" />

            <!-- Month navigator row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageButton
                    android:id="@+id/btnPrevMonth"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@drawable/bg_icon_button"
                    android:contentDescription="Previous month"
                    android:src="@drawable/ic_chevron_left"
                    app:tint="@color/primary" />

                <TextView
                    android:id="@+id/tvMonthLabel"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="@font/manrope_extra_bold"
                    android:gravity="center"
                    android:textColor="@color/on_surface"
                    android:textSize="24sp"
                    tools:text="October 2024" />

                <ImageButton
                    android:id="@+id/btnNextMonth"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@drawable/bg_icon_button"
                    android:contentDescription="Next month"
                    android:src="@drawable/ic_chevron_right"
                    app:tint="@color/primary" />

            </LinearLayout>
        </LinearLayout>

        <!-- ── SPENDING SUMMARY CARD (PieChart) ───────────────── -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="16dp"
            app:cardBackgroundColor="@color/surface_container_lowest"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <!-- PieChart -->
                <com.github.mikephil.charting.charts.PieChart
                    android:id="@+id/pieChart"
                    android:layout_width="220dp"
                    android:layout_height="220dp"
                    android:layout_gravity="center_horizontal" />

                <!-- Center info (drawn programmatically via CenterText,
                     but we add a summary row below for clarity) -->

                <!-- Trend row -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="8dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:id="@+id/ivTrendIcon"
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_arrow_downward"
                        app:tint="@color/tertiary" />

                    <TextView
                        android:id="@+id/tvTrendPercent"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:fontFamily="@font/inter_semi_bold"
                        android:textColor="@color/tertiary"
                        android:textSize="13sp"
                        tools:text="8.4% vs last month" />
                </LinearLayout>

                <!-- Custom Legend (RecyclerView, populated in Fragment) -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvPieLegend"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:nestedScrollingEnabled="false"
                    tools:itemCount="4"
                    tools:listitem="@layout/item_legend" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ── KEY INSIGHTS ────────────────────────────────────── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="28dp"
            android:drawableStart="@drawable/ic_insights"
            android:drawablePadding="8dp"
            android:drawableTint="@color/primary"
            android:fontFamily="@font/manrope_bold"
            android:gravity="center_vertical"
            android:text="Key Insights"
            android:textColor="@color/on_surface"
            android:textSize="18sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <!-- Highest Spend card -->
            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                app:cardBackgroundColor="#1A004D64"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/inter_bold"
                        android:letterSpacing="0.12"
                        android:text="HIGHEST SPEND"
                        android:textAllCaps="true"
                        android:textColor="@color/primary_container"
                        android:textSize="9sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <ImageView
                            android:id="@+id/ivHighestCategoryIcon"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:background="@drawable/bg_circle_primary"
                            android:padding="8dp"
                            android:src="@drawable/ic_home"
                            app:tint="@color/on_primary" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvHighestCategoryName"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/inter_bold"
                                android:textColor="@color/on_surface"
                                android:textSize="13sp"
                                tools:text="Housing" />

                            <TextView
                                android:id="@+id/tvHighestCategoryPercent"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/inter"
                                android:textColor="@color/on_surface_variant"
                                android:textSize="11sp"
                                tools:text="42% of budget" />

                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Est. Savings card -->
            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                app:cardBackgroundColor="#1A1A6C23"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/inter_bold"
                        android:letterSpacing="0.12"
                        android:text="EST. SAVINGS"
                        android:textAllCaps="true"
                        android:textColor="@color/tertiary_container"
                        android:textSize="9sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <ImageView
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:background="@drawable/bg_circle_tertiary"
                            android:padding="8dp"
                            android:src="@drawable/ic_savings"
                            app:tint="@color/on_tertiary" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvEstSavings"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/inter_bold"
                                android:textColor="@color/on_surface"
                                android:textSize="13sp"
                                tools:text="$1,240" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/inter"
                                android:text="This Month"
                                android:textColor="@color/on_surface_variant"
                                android:textSize="11sp" />

                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>

        <!-- ── MONTHLY COMPARISON (BarChart) ──────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="28dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="@font/manrope_bold"
                android:text="Monthly Comparison"
                android:textColor="@color/on_surface"
                android:textSize="18sp" />

            <TextView
                android:id="@+id/tvBarChartAvg"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/inter"
                android:textColor="@color/on_surface_variant"
                android:textSize="12sp"
                tools:text="Avg: $4,200" />
        </LinearLayout>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="12dp"
            app:cardBackgroundColor="@color/surface_container_low"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp">

            <com.github.mikephil.charting.charts.BarChart
                android:id="@+id/barChart"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:paddingHorizontal="12dp"
                android:paddingVertical="16dp" />

        </androidx.cardview.widget.CardView>

        <!-- ── INTENSITY REPORT ────────────────────────────────── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="28dp"
            android:fontFamily="@font/manrope_bold"
            android:text="Intensity Report"
            android:textColor="@color/on_surface"
            android:textSize="18sp" />

        <!-- Empty state (shown when no data) -->
        <LinearLayout
            android:id="@+id/layoutIntensityEmpty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="12dp"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="32dp"
            android:visibility="gone">

            <ImageView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:alpha="0.3"
                android:src="@drawable/ic_insights"
                app:tint="@color/on_surface_variant" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:fontFamily="@font/inter"
                android:gravity="center"
                android:text="No transactions this month"
                android:textColor="@color/on_surface_variant"
                android:textSize="14sp" />

        </LinearLayout>

        <!-- Intensity list (populated dynamically) -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvIntensity"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="12dp"
            android:nestedScrollingEnabled="false"
            tools:itemCount="3"
            tools:listitem="@layout/item_intensity_report" />

        <!-- bottom spacer -->
        <View
            android:layout_width="match_parent"
            android:layout_height="16dp" />

    </LinearLayout>
</ScrollView>