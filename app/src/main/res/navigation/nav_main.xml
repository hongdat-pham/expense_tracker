<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_main"
    app:startDestination="@id/overviewFragment">

    <fragment
        android:id="@+id/overviewFragment"
        android:name="com.example.expense_tracker.ui.overview.OverviewFragment"
        android:label="Overview">
        <action
            android:id="@+id/action_overview_to_newTransaction"
            app:destination="@id/newTransactionFragment" />
        <!-- THÊM ACTION NÀY -->
        <action
            android:id="@+id/action_overview_to_activity"
            app:destination="@id/activityFragment" />
    </fragment>

    <fragment
        android:id="@+id/activityFragment"
        android:name="com.example.expense_tracker.ui.activity.ActivityFragment"
        android:label="Activity">
        <action
            android:id="@+id/action_activity_to_newTransaction"
            app:destination="@id/newTransactionFragment" />
        <action
            android:id="@+id/action_activity_to_detail"
            app:destination="@id/activityDetailFragment" />
    </fragment>

    <fragment
        android:id="@+id/analyticsFragment"
        android:name="com.example.expense_tracker.ui.analytics.AnalyticsFragment"
        android:label="Analytics" />

    <fragment
        android:id="@+id/settingsFragment"
        android:name="com.example.expense_tracker.ui.settings.SettingsFragment"
        android:label="Settings">
        <action
            android:id="@+id/action_settings_to_manageAccount"
            app:destination="@id/manageAccountFragment" />
        <action
            android:id="@+id/action_settings_to_budgetLimits"
            app:destination="@id/budgetLimitsFragment" />
    </fragment>

    <fragment
        android:id="@+id/newTransactionFragment"
        android:name="com.example.expense_tracker.ui.transaction.NewTransactionFragment"
        android:label="New Transaction" />

    <fragment
        android:id="@+id/activityDetailFragment"
        android:name="com.example.expense_tracker.ui.activity.ActivityDetailFragment"
        android:label="Activity Detail">
        <argument
            android:name="transactionId"
            app:argType="long" />
    </fragment>

    <fragment
        android:id="@+id/manageAccountFragment"
        android:name="com.example.expense_tracker.ui.settings.account.ManageAccountFragment"
        android:label="Manage Accounts" />

    <fragment
        android:id="@+id/budgetLimitsFragment"
        android:name="com.example.expense_tracker.ui.settings.budget.BudgetLimitsFragment"
        android:label="Budget Limits" />

</navigation>