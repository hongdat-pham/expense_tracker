<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F7F9FF">

    <!-- Top App Bar -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#F7F9FF"
        app:elevation="0dp">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:paddingStart="8dp"
            android:paddingEnd="8dp">

            <!-- Close Button -->
            <ImageButton
                android:id="@+id/btnClose"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Close"
                android:src="@drawable/ic_close"
                app:tint="#181C20" />

            <!-- Title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:fontFamily="sans-serif-medium"
                android:text="New Transaction"
                android:textColor="#004D64"
                android:textSize="18sp"
                android:textStyle="bold" />

        </androidx.appcompat.widget.Toolbar>

    </com.google.android.material.appbar.AppBarLayout>

    <!-- Scrollable Content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="100dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingEnd="24dp">

            <!-- ===================== AMOUNT SECTION ===================== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:layout_marginBottom="32dp"
                android:gravity="center"
                android:orientation="vertical">

                <!-- "Amount" Label -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.15"
                    android:text="AMOUNT"
                    android:textAllCaps="true"
                    android:textColor="#3F484D"
                    android:textSize="10sp" />

                <!-- Dollar Sign + Amount Input Row -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-black"
                        android:text="$"
                        android:textColor="#80006684"
                        android:textSize="28sp"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/etAmount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:background="@null"
                        android:fontFamily="sans-serif-black"
                        android:gravity="center"
                        android:hint="0.00"
                        android:inputType="numberDecimal"
                        android:minWidth="120dp"
                        android:textColor="#004D64"
                        android:textColorHint="#DFE3E8"
                        android:textSize="56sp"
                        android:textStyle="bold" />

                </LinearLayout>

            </LinearLayout>

            <!-- ===================== CATEGORY SECTION ===================== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="32dp"
                android:orientation="vertical">

                <!-- Category Header -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:fontFamily="sans-serif-medium"
                        android:text="Category"
                        android:textColor="#181C20"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvViewAll"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-medium"
                        android:text="View All"
                        android:textColor="#004D64"
                        android:textSize="12sp" />

                </LinearLayout>

                <!-- Category Grid -->
                <GridLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:columnCount="4"
                    android:rowCount="1">

                    <!-- Dining (Selected) -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="4dp">

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/categoryDining"
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            app:cardBackgroundColor="#006684"
                            app:cardCornerRadius="12dp"
                            app:cardElevation="4dp">

                            <ImageView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:contentDescription="Dining"
                                android:src="@drawable/ic_restaurant"
                                app:tint="#FFFFFF" />

                        </com.google.android.material.card.MaterialCardView>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:fontFamily="sans-serif-medium"
                            android:text="Dining"
                            android:textColor="#004D64"
                            android:textSize="10sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <!-- Shopping -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="4dp">

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/categoryShopping"
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            app:cardBackgroundColor="#FFFFFF"
                            app:cardCornerRadius="12dp"
                            app:cardElevation="0dp"
                            app:strokeColor="#DFE3E8"
                            app:strokeWidth="1dp">

                            <ImageView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:contentDescription="Shopping"
                                android:src="@drawable/ic_shopping_cart"
                                app:tint="#3F484D" />

                        </com.google.android.material.card.MaterialCardView>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:fontFamily="sans-serif"
                            android:text="Shopping"
                            android:textColor="#3F484D"
                            android:textSize="10sp" />

                    </LinearLayout>

                    <!-- Travel -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="4dp">

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/categoryTravel"
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            app:cardBackgroundColor="#FFFFFF"
                            app:cardCornerRadius="12dp"
                            app:cardElevation="0dp"
                            app:strokeColor="#DFE3E8"
                            app:strokeWidth="1dp">

                            <ImageView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:contentDescription="Travel"
                                android:src="@drawable/ic_directions_car"
                                app:tint="#3F484D" />

                        </com.google.android.material.card.MaterialCardView>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:fontFamily="sans-serif"
                            android:text="Travel"
                            android:textColor="#3F484D"
                            android:textSize="10sp" />

                    </LinearLayout>

                    <!-- Housing -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="4dp">

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/categoryHousing"
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            app:cardBackgroundColor="#FFFFFF"
                            app:cardCornerRadius="12dp"
                            app:cardElevation="0dp"
                            app:strokeColor="#DFE3E8"
                            app:strokeWidth="1dp">

                            <ImageView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:contentDescription="Housing"
                                android:src="@drawable/ic_home"
                                app:tint="#3F484D" />

                        </com.google.android.material.card.MaterialCardView>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:fontFamily="sans-serif"
                            android:text="Housing"
                            android:textColor="#3F484D"
                            android:textSize="10sp" />

                    </LinearLayout>

                </GridLayout>

            </LinearLayout>

            <!-- ===================== DATE SECTION ===================== -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardDate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="12dp"
                app:cardElevation="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="16dp">

                    <!-- Calendar Icon Background -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        app:cardBackgroundColor="#F1F4FA"
                        app:cardCornerRadius="8dp"
                        app:cardElevation="0dp">

                        <ImageView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:contentDescription="Date"
                            android:src="@drawable/ic_calendar_today"
                            app:tint="#004D64" />

                    </com.google.android.material.card.MaterialCardView>

                    <!-- Date Text -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif"
                            android:text="Transaction Date"
                            android:textColor="#3F484D"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/tvDate"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif-medium"
                            android:text="Today, Oct 24, 2023"
                            android:textColor="#181C20"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <!-- Chevron -->
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:contentDescription="Select date"
                        android:src="@drawable/ic_chevron_right"
                        app:tint="#3F484D" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- ===================== PAYMENT METHOD SECTION ===================== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:orientation="vertical">

                <!-- Payment Method Header -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:layout_marginStart="4dp"
                    android:fontFamily="sans-serif-medium"
                    android:text="Payment Method"
                    android:textColor="#181C20"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <!-- Horizontal Scrollable Payment Methods -->
                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="none">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <!-- Cash (Selected) -->
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnCash"
                            style="@style/Widget.MaterialComponents.Button"
                            android:layout_width="wrap_content"
                            android:layout_height="40dp"
                            android:layout_marginEnd="8dp"
                            android:backgroundTint="#004D64"
                            android:fontFamily="sans-serif-medium"
                            android:icon="@drawable/ic_payments"
                            android:iconTint="#FFFFFF"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp"
                            android:text="Cash"
                            android:textColor="#FFFFFF"
                            android:textSize="12sp"
                            app:cornerRadius="8dp" />

                        <!-- Visa Card -->
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnVisa"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="wrap_content"
                            android:layout_height="40dp"
                            android:layout_marginEnd="8dp"
                            android:fontFamily="sans-serif"
                            android:icon="@drawable/ic_credit_card"
                            android:iconTint="#3F484D"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp"
                            android:text="Visa •••• 4242"
                            android:textColor="#3F484D"
                            android:textSize="12sp"
                            app:cornerRadius="8dp"
                            app:strokeColor="#BFCAC5"
                            app:strokeWidth="1dp" />

                        <!-- Apple Pay -->
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnApplePay"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="wrap_content"
                            android:layout_height="40dp"
                            android:fontFamily="sans-serif"
                            android:icon="@drawable/ic_contactless"
                            android:iconTint="#3F484D"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp"
                            android:text="Apple Pay"
                            android:textColor="#3F484D"
                            android:textSize="12sp"
                            app:cornerRadius="8dp"
                            app:strokeColor="#BFCAC5"
                            app:strokeWidth="1dp" />

                    </LinearLayout>

                </HorizontalScrollView>

            </LinearLayout>

            <!-- ===================== DESCRIPTION SECTION ===================== -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="12dp"
                app:cardElevation="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="top"
                    android:orientation="horizontal"
                    android:padding="16dp">

                    <!-- Notes Icon Background -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        app:cardBackgroundColor="#F1F4FA"
                        app:cardCornerRadius="8dp"
                        app:cardElevation="0dp">

                        <ImageView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:contentDescription="Notes"
                            android:src="@drawable/ic_notes"
                            app:tint="#004D64" />

                    </com.google.android.material.card.MaterialCardView>

                    <!-- Notes Input -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif"
                            android:text="Description"
                            android:textColor="#3F484D"
                            android:textSize="12sp" />

                        <EditText
                            android:id="@+id/etDescription"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:background="@null"
                            android:fontFamily="sans-serif"
                            android:gravity="top|start"
                            android:hint="What was this for?"
                            android:inputType="textMultiLine|textCapSentences"
                            android:lines="2"
                            android:maxLines="4"
                            android:minLines="2"
                            android:textColor="#181C20"
                            android:textColorHint="#70787E"
                            android:textSize="14sp" />

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- ===================== ADD RECEIPT SECTION ===================== -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardAddReceipt"
                android:layout_width="match_parent"
                android:layout_height="128dp"
                android:layout_marginBottom="24dp"
                app:cardBackgroundColor="#E5E8EE"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp">

                <!-- Receipt Background Image (dimmed) -->
                <ImageView
                    android:id="@+id/ivReceiptPreview"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:alpha="0.3"
                    android:contentDescription="Receipt preview"
                    android:scaleType="centerCrop"
                    android:visibility="gone" />

                <!-- Overlay Content -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:contentDescription="Add receipt"
                        android:src="@drawable/ic_add_a_photo"
                        app:tint="#004D64" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:fontFamily="sans-serif-medium"
                        android:letterSpacing="0.12"
                        android:text="ADD RECEIPT"
                        android:textAllCaps="true"
                        android:textColor="#006684"
                        android:textSize="10sp"
                        android:textStyle="bold" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- ===================== FIXED BOTTOM SAVE BUTTON ===================== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="#CFF7F9FF"
        android:paddingStart="24dp"
        android:paddingTop="12dp"
        android:paddingEnd="24dp"
        android:paddingBottom="32dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSaveTransaction"
            style="@style/Widget.MaterialComponents.Button"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:fontFamily="sans-serif-medium"
            android:text="Save Transaction"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textAllCaps="false"
            app:backgroundTint="#006684"
            app:cornerRadius="12dp"
            app:elevation="8dp" />

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>